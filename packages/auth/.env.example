# Development: set values in repo root `.env.local` (loaded via `.envrc`).
# Vercel: mirror the same variable names on each project.

# IdP / shared Postgres — canonical: PRISMA_DATABASE_URL (Prisma Data Platform)
# PRISMA_DATABASE_URL=
# DATABASE_URL=

# OAuth client apps only (session store — separate from IdP user DB)
# AUTH_DEPLOYMENT_ROLE=client
# AUTH_CLIENT_DATABASE_URL=
# AUTH_OAUTH_SITE_KEY=ARMY
# AUTH_ARMY_SESSION_DATABASE_URL=

AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_PASSKEY_RP_ID=localhost
AUTH_PASSKEY_RP_NAME=awfixer.army
AUTH_TRUSTED_ORIGINS=

# IdP only — comma-separated usernames promoted via `bun run promote-admins`
# AUTH_ADMIN_USERNAMES=awfixer

# IdP only — Snowflake worker id (divisible across Vercel instances, 0–1023)
# AUTH_SNOWFLAKE_WORKER_ID=0

# IdP only — one block per satellite app (see src/oauth-sites.ts)
# AUTH_OAUTH_ARMY_CLIENT_ID=awfixer-army
# AUTH_OAUTH_ARMY_CLIENT_SECRET=
# AUTH_OAUTH_ACCOUNT_CLIENT_ID=awfixer-account
# AUTH_OAUTH_ACCOUNT_CLIENT_SECRET=