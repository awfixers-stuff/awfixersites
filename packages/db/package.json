    "format": "oxfmt -c ../../src/fmt.json . --check",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest -c vitest.config.ts",
    "lint:fix": "oxlint -c ../../src/lint.json . --fix"
  },
  "dependencies": {
    "@awfixersites/env": "catalog:",
    "@awfixersites/ui": "catalog:",
