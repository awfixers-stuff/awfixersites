{
  "name": "@awfixersites/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./prisma": "./src/prisma.ts",
    "./enlistments": "./src/enlistments.ts",
    "./hooks": "./src/hooks.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "push": "prisma db push",
