{
  "name": "@awfixersites/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./codes.css": "./src/styles/codes.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./background": "./src/background/motion-background.tsx",
    "./background/index": "./src/background/index.ts",
    "./background/*": "./src/background/*",
    "./auth": "./src/auth/index.ts",
    "./auth/*": "./src/auth/*",
    "./enlist": "./src/enlist/index.ts",
    "./enlist/*": "./src/enlist/*"
  },
  "scripts": {
    "lint": "oxlint -c ../../src/lint.json .",
    "format": "oxfmt -c ../../src/fmt.json . --check",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest -c vitest.config.ts",
    "lint:fix": "oxlint -c ../../src/lint.json . --fix"
  },
  "dependencies": {
    "@awfixersites/auth": "catalog:workspace",
    "class-variance-authority": "catalog:css",
    "clsx": "catalog:css",
    "lucide-react": "catalog:react",
    "motion": "catalog:react",
    "next-themes": "catalog:nextjs",
    "radix-ui": "catalog:react",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "shadcn": "catalog:",
    "tailwind-merge": "catalog:css",
    "tw-animate-css": "catalog:css",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:css",
    "@tailwindcss/typography": "catalog:css",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "next": "catalog:nextjs",
    "tailwindcss": "catalog:css",
    "typescript": "catalog:checking"
  }
}
