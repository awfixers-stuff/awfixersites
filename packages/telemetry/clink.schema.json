{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://awfixersites.dev/schemas/clink.json",
  "title": "CLink config",
  "description": "Per-app configuration for @awfixersites/telemetry CLink component",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference",
      "description": "JSON Schema reference for editor validation"
    },
    "network": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Domains treated as internal to the awfixer ecosystem"
    },
    "utm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Default utm_source appended to external links"
        },
        "medium": {
          "type": "string",
          "default": "referral",
          "description": "Default utm_medium appended to external links"
        },
        "campaign": {
          "type": ["string", "null"],
          "default": null,
          "description": "Default utm_campaign appended to external links"
        }
      }
    },
    "click": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "event": {
          "type": "string",
          "default": "link_clicked",
          "description": "Event name fired on every CLink click"
        },
        "properties": {
          "type": "object",
          "additionalProperties": true,
          "default": {},
          "description": "Extra properties merged into every automatic track() call"
        }
      },
      "default": { "event": "link_clicked", "properties": {} }
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Glob/regex patterns CLink passes through untouched"
    }
  }
}
