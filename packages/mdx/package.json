  },
  "devDependencies": {
    "@types/mdx": "catalog:types",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "next": "catalog:nextjs",
    "react": "catalog:react",
    "typescript": "catalog:checking"
  }
