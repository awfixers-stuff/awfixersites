{
  "name": "@awfixersites/mdx",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components.tsx",
    "./next": "./src/next.ts",
    "./types": "./mdx.d.ts"
  },
  "scripts": {
    "lint": "oxlint -c ../../src/lint.json .",
    "format": "oxfmt -c ../../src/fmt.json . --check",
