{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../src/tsconfig.next.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@awfixersites/auth": ["../../packages/auth/src/index.ts"],
      "@awfixersites/auth/*": ["../../packages/auth/src/*"],
      "@awfixersites/db": ["../../packages/db/src/index.ts"],
      "@awfixersites/db/*": ["../../packages/db/src/*"],
      "@awfixersites/ui/*": ["../../packages/ui/src/*"],
      "@awfixersites/mdx": ["../../packages/mdx/src/index.ts"],
      "@awfixersites/mdx/*": ["../../packages/mdx/src/*", "../../packages/mdx/*"],
      "@awfixersites/content/*": ["../../packages/content/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "../../packages/mdx/mdx.d.ts",
    "next.config.ts",
    "vercel.ts",
    "vitest.config.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mdx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
