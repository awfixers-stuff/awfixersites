# Development: copy auth/db URLs and secrets into repo root `.env.local`.

# DATABASE_URL=          # enlistments (@awfixersites/db)
# PRISMA_DATABASE_URL=   # same Postgres as auth when using Prisma Data Platform

# AUTH_SECRET=
# BETTER_AUTH_URL=https://auth.awfixer.me
# AUTH_URL=https://auth.awfixer.me

# OAuth client (if army uses local session DB instead of IdP-only)
# AUTH_DEPLOYMENT_ROLE=client
# AUTH_CLIENT_DATABASE_URL=
NEXT_PUBLIC_API_URL=https://api.awfixer.me
NEXT_PUBLIC_AUTH_API_URL=https://api.awfixer.me/oauth
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
