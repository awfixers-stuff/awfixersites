{
  "name": "@awfixersites/account",
  "version": "0.0.1",
  "private": true,
  "description": "AWFixer account dashboard at account.awfixer.me",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3020",
    "build": "bun --bun ../../scripts/vercel-build.ts",
    "start": "next start",
    "lint": "oxlint -c ../../src/lint.json .",
    "format": "oxfmt -c ../../src/fmt.json . --check",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest -c vitest.config.ts",
    "lint:fix": "oxlint -c ../../src/lint.json . --fix"
  },
  "dependencies": {
    "@awfixersites/auth": "catalog:workspace",
    "@awfixersites/security": "catalog:workspace",
    "@awfixersites/telemetry": "catalog:workspace",
    "@awfixersites/ui": "catalog:workspace",
    "@awfixersites/utils": "catalog:workspace",
    "@esbuild/linux-x64": "0.28.1",
    "@next/swc-linux-x64-gnu": "catalog:nextjs",
    "@oxfmt/binding-linux-x64-gnu": "catalog:bindings",
    "@oxlint-tsgolint/linux-x64": "catalog:bindings",
    "@oxlint/binding-linux-x64-gnu": "catalog:bindings",
    "@rolldown/binding-linux-x64-gnu": "catalog:bindings",
    "@tailwindcss/oxide-linux-x64-gnu": "catalog:css",
    "@tailwindcss/postcss": "catalog:css",
    "@typescript/native-preview-linux-x64": "7.0.0-dev.20260630.1",
    "@vercel/analytics": "catalog:vercel",
    "@vercel/speed-insights": "catalog:vercel",
    "botid": "catalog:vercel",
    "class-variance-authority": "catalog:css",
    "clsx": "catalog:css",
    "lightningcss-linux-x64-gnu": "catalog:css",
    "lucide-react": "catalog:react",
    "motion": "catalog:react",
    "next": "catalog:nextjs",
    "next-themes": "catalog:nextjs",
    "radix-ui": "catalog:react",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "shadcn": "catalog:",
    "tailwind-merge": "catalog:css",
    "tailwindcss": "catalog:css",
    "tw-animate-css": "catalog:css"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "error"
    },
    "runtime": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "error"
    }
  },
  "engines": {
    "bun": "1.3.14"
  },
  "engineStrict": true,
  "packageManager": "bun@1.3.14"
}
