  "scripts": {
    "lint": "oxlint -c ./src/lint.json .",
    "lint:fix": "oxlint -c ./src/lint.json . --fix",
    "lint:security": "oxlint -c ./src/lint.security.json apps packages src",
    "lint:security:types": "oxlint -c ./src/lint.security.json apps packages src --type-aware -D typescript/no-unsafe-argument -D typescript/no-unsafe-assignment -D typescript/no-unsafe-call -D typescript/no-unsafe-member-access -D typescript/no-unsafe-return -D typescript/restrict-template-expressions",
    "lint:ci": "bun --bun scripts/lint-all.ts",
    "format": "oxfmt -c ./src/fmt.json . --write",
    "typecheck": "bun --bun scripts/typecheck-all.ts",
    "typecheck:src": "tsgo -p ./src/tsconfig.json --noEmit --pretty",
    "test:browser": "vitest -c ./src/vitest.config.ts .",
    "auth:generate": "bun run --cwd packages/auth generate",
    "auth:push": "bun scripts/prisma-push.ts auth",
    "db:generate": "bun run --cwd packages/db generate",
    "db:push": "bun scripts/prisma-push.ts db",
    "prisma:push": "bun scripts/prisma-push.ts all",
    "prisma:generate": "bun run auth:generate && bun run db:generate"
  },
  "dependencies": {
    "@socketsecurity/bun-security-scanner": "catalog:",
    "@typescript/native-preview": "catalog:checking",
    "@typescript/native-preview-linux-x64": "catalog:bindings",
    "typescript": "catalog:checking"
  },
  "devDependencies": {
    "@oxfmt/binding-linux-x64-gnu": "catalog:bindings",
    "@oxlint-tsgolint/linux-x64": "catalog:bindings",
    "@oxlint/binding-linux-x64-gnu": "catalog:bindings",
    "@rolldown/binding-linux-x64-gnu": "catalog:bindings",
    "@types/bun": "catalog:types",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@vercel/config": "catalog:vercel",
    "@vitejs/plugin-react": "catalog:checking",
    "@vitest/browser-playwright": "catalog:checking",
    "@vitest/utils": "catalog:checking",
    "eslint-plugin-no-secrets": "catalog:checking",
    "eslint-plugin-security": "catalog:checking",
    "eslint-plugin-sonarjs": "catalog:checking",
    "oxfmt": "catalog:checking",
    "oxlint": "catalog:checking",
    "oxlint-tsgolint": "catalog:checking",
    "vitest": "catalog:checking",
    "vitest-browser-react": "catalog:checking"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13",
    "path-to-regexp": ">=4.0.0",
    "postcss": ">=8.5.10",
    "uuid": ">=11.1.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "error"
    },
    "runtime": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "error"
    }
  },
  "engines": {
    "bun": "1.3.14"
  },
  "engineStrict": true,
  "packageManager": "bun@1.3.14"
}
