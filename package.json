{
  "name": "@awfixersites/mono",
  "version": "0.0.1",
  "private": true,
  "description": "the monorepo for AWFixer sites",
  "homepage": "https://github.com/awfixers-stuff",
  "author": {
    "name": "AWFixer LLC",
    "email": "developers@awfixer.llc",
    "url": "https://awfixer.llc"
  },
  "contributors": [
    {
      "name": "awfixer",
      "email": "contact@theautist.me",
      "url": "https://theautist.me"
    },
    {
      "name": "autoawfixer (aka AWFixer Auto, or the Auto AWFixer App)",
      "email": "contact@agent.awfixer.codes",
      "url": "https://agent.awfixer.codes"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/awfixers-stuff/awfixersites"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@vercel/analytics": "2.0.1",
      "@vercel/speed-insights": "2.0.0",
      "@tailwindcss/postcss": "4.3.1",
      "class-variance-authority": "0.7.1",
      "clsx": "2.1.1",
      "lucide-react": "1.22.0",
      "motion": "12.42.0",
      "next": "16.2.9",
      "next-themes": "0.4.6",
      "radix-ui": "1.6.0",
      "react": "19.2.7",
      "react-dom": "19.2.7",
      "shadcn": "4.12.0",
      "tailwind-merge": "3.6.0",
      "tailwindcss": "4.3.2",
      "tw-animate-css": "1.4.0",
      "@awfixersites/ui": "workspace:*",
      "@types/bun": "1.3.14",
      "@types/node": "26.0.1",
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3",
      "lightningcss": "1.32.0",
      "@tailwindcss/oxide-linux-x64-gnu": "4.3.2",
      "lightningcss-linux-x64-gnu": "1.32.0",
      "@next/swc-linux-x64-gnu": "16.2.9",
      "typescript": "6.0.3"
    }
  },
  "scripts": {
    "lint": "oxlint -c ./src/lint.json . --fix",
    "format": "oxfmt -c ./src/fmt.json . --write",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260630.1",
    "@typescript/native-preview-linux-x64": "7.0.0-dev.20260630.1",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@oxfmt/binding-linux-x64-gnu": "0.56.0",
    "@oxlint/binding-linux-x64-gnu": "1.71.0",
    "@socketsecurity/bun-security-scanner": "1.1.2",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/utils": "4.1.9",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "vercel": "54.18.0",
    "vitest": "4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.4.0",
      "onFail": "error"
    },
    "runtime": {
      "name": "bun",
      "version": "1.4.0",
      "onFail": "error"
    }
  },
  "engines": {
    "bun": "1.3.14"
  },
  "engineStrict": true,
  "packageManager": "bun@1.3.14"
}
